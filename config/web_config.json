{
  "playwright": {
    "browser": {
      "type": "chromium",
      "headless": true,
      "slow_mo": 100,
      "timeout": 30000
    },
    "context": {
      "viewport": {
        "width": 1280,
        "height": 720
      },
      "ignore_https_errors": true,
      "accept_downloads": true
    },
    "trace": {
      "enabled": false,
      "screenshots": true,
      "snapshots": true,
      "sources": true
    },
    "video": {
      "enabled": false,
      "dir": "./test-results/videos"
    },
    "screenshot": {
      "enabled": true,
      "dir": "./test-results/screenshots",
      "full_page": true,
      "only_on_failure": true
    }
  },
  "test": {
    "base_url": "http://localhost:3000",
    "timeout": 10000,
    "retry": 2
  }
}